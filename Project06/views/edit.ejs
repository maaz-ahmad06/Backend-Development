<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full h-screen bg-zinc-900 text-white p-10">
        <div class="w-full flex justify-end">
            <a class="bg-red-500 rounded-md px-3 py-2 mb-5 online-block text-sm" href="/logout">Logout</a>
        </div>
        <h5 class="mb-5">edit your post.</h5>
        <form action="/update/<%= post._id %>" method="post">
            <textarea placeholder="what's on your mind ?" class="block resize-none bg-transparent border-2 border-zinc-800 rounded-md p-3 outline-none w-1/3" name="content"><%= post.content %></textarea>
            <input class="px-3 py-2 w-40 bg-yellow-500 text-black block rounded-md mt-2 text-sm" type="submit" value="Update Post">
        </form>
    </div>
</body>
</html>