<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheet/style.css">
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full h-full bg-zinc-900 text-white p-10">
        <div class="nav mb-10">
            <a class="text-blue-500" href="/read">View Users</a>
        </div>
        <h1 class="text-3xl tracking-tighter mb-3">Create User</h1>
        <form action="/create" method="post">
            <input class="px-5 py-2 border-2 border-zinc-800 rounded-lg outline-none bg-transparent" type="text" name="name" placeholder="Name">
            <input class="px-5 py-2 border-2 border-zinc-800 rounded-lg outline-none bg-transparent" type="text" name="email" placeholder="Email">
            <input class="px-5 py-2 border-2 border-zinc-800 rounded-lg outline-none bg-transparent" type="text" name="image" placeholder="Image URL">
            <input class="px-5 py-2 bg-blue-500 rounded-lg mml-2" type="submit" value="Create User">
        </form>
    </div>
</body>
</html>